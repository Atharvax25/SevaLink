# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/sevalink?retryWrites=true&w=majority&appName=SevaLink

# Auth
TOKEN_SECRET=replace-with-a-long-random-secret

# Optional email settings
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-password
# MAIL_FROM=noreply@sevalink.local
